# DramaPipeline 环境变量示例
# 复制为 .env 并填入真实值

# 通义千问 API Key（用于 AI 能力）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 模型名称（可选，默认 qwen3.5-plus）
DASHSCOPE_MODEL=qwen3.5-plus

# Flask 端口（默认 5001，macOS 上 5000 常被 AirPlay 占用）
FLASK_PORT=5001

# SQLite 数据库路径（可选，默认 backend/dramapipeline.db）
# SQLITE_PATH=./dramapipeline.db
